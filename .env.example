# Existing Google Apps Script /exec web app URL.
JORDANA_APPS_SCRIPT_URL=

# Existing Apps Script ingest key. Keep the real value only in .env.
JORDANA_INGEST_API_KEY=

# Pending replacement key generated locally during rotation.
# Promote to JORDANA_INGEST_API_KEY only after the existing Apps Script
# deployment has the same value in Script Properties.
JORDANA_PENDING_INGEST_API_KEY=

# Optional Apps Script administration values for maintaining the existing deployment.
JORDANA_SPREADSHEET_ID=
JORDANA_APPS_SCRIPT_PROJECT_ID=
JORDANA_APPS_SCRIPT_DEPLOYMENT_ID=

# Local SQLite database path. Use an absolute path for the launcher.
JORDANA_DATABASE_PATH=__PROJECT_DIR__/data/jordana_invoice.sqlite3

# Local development report output directory.
# Installed releases set this to ~/Documents/Jordana Billing/Session Lists.
JORDANA_REPORTS_DIR=__PROJECT_DIR__/Reports

# Calendar sync runs automatically while the local app is open.
JORDANA_CALENDAR_SYNC_INTERVAL_MINUTES=15

# Optional path for exported Google Sheets CSV files.
JORDANA_IMPORT_DIR=__PROJECT_DIR__/data/imports

# Optional future work-calendar preference. Missing value preserves existing all-calendar behavior.
JORDANA_PREFERRED_WORK_CALENDAR=Jordana Work

# Local development invoice/receipt output directories.
# Installed releases set both to ~/Documents/Jordana Billing/Client Files.
JORDANA_INVOICES_DIR=Invoices
JORDANA_RECEIPTS_DIR=Receipts

# Calendar capture configuration.
JORDANA_TIMEZONE=America/New_York
JORDANA_RAW_SHEET=Raw_Event_Snapshots
JORDANA_RUN_LOG_SHEET=Run_Log
JORDANA_NORMAL_PAST_DAYS=3
JORDANA_NORMAL_FUTURE_DAYS=7
JORDANA_PAST_CAPTURE_WINDOW=past_3_days
JORDANA_FUTURE_CAPTURE_WINDOW=next_7_days
JORDANA_BACKFILL_START_DATE=2026-06-01T00:00:00-04:00
JORDANA_BACKFILL_END_DATE=2026-06-14T23:59:59-04:00
JORDANA_BACKFILL_CAPTURE_WINDOW=backfill_2026_06_01_through_2026_06_14
JORDANA_NORMAL_SHORTCUT_NAME=Jordana Calendar Snapshot v2
JORDANA_BACKFILL_SHORTCUT_NAME=Jordana Calendar Backfill - June 1-14, 2026
JORDANA_PAYLOAD_VERSION=2

# Phase 2 uses the same sync secrets. Rate/review data stays in SQLite.
