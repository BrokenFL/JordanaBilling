# Existing Google Apps Script /exec web app URL.
JORDANA_APPS_SCRIPT_URL=

# Existing Apps Script ingest key. Keep the real value only in .env.
JORDANA_INGEST_API_KEY=

# Local SQLite database path.
JORDANA_DATABASE_PATH=/Users/brookesnader/Documents/Jordana Billing/data/jordana_invoice.sqlite3

# Local report output directory.
JORDANA_REPORTS_DIR=/Users/brookesnader/Documents/Jordana Billing/Reports

# Optional path for exported Google Sheets CSV files.
JORDANA_IMPORT_DIR=/Users/brookesnader/Documents/Jordana Billing/data/imports

# Optional future work-calendar preference. Missing value preserves existing all-calendar behavior.
JORDANA_PREFERRED_WORK_CALENDAR=Jordana Work
JORDANA_INVOICES_DIR=Invoices

# Phase 2 uses the same sync secrets. Rate/review data stays in SQLite.
